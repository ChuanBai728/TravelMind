# Anthropic Messages-compatible LLM provider (main model).
LLM_PROVIDER=mimo
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_CHAT_PATH=/v1/messages
MIMO_API_KEY=
MIMO_MODEL=
MIMO_INTENT_MODEL=
MIMO_TEMPERATURE=0.4
MIMO_TIMEOUT_SECONDS=60

# OpenAI-compatible LLM provider (for intent parsing with small model, e.g. SiliconFlow).
OPENAI_BASE_URL=https://api.siliconflow.cn
OPENAI_CHAT_PATH=/v1/chat/completions
OPENAI_API_KEY=
OPENAI_MODEL=Qwen/Qwen3-8B
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT_SECONDS=30

AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_TIMEOUT_SECONDS=20

EXPORT_DIR=exports
